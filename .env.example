# Local MongoDB defaults for MentalHealthIQ.
# For local MongoDB Compass, connect using:
# mongodb://localhost:27017

MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=mentalhealthiq
MONGODB_COLLECTION=predictions

# If FastAPI runs inside Docker Compose, use:
# MONGODB_URI=mongodb://mongodb:27017
#
# Atlas can also be used later, but do not commit real Atlas credentials.
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net
